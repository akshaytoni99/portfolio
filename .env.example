# ── Frontend (Vite) ──────────────────────────────────────────────
# Secret admin route. Change from the default for obscurity.
VITE_ADMIN_ROUTE=/admin-portal

# Backend base URL. LEAVE EMPTY for local dev (same-origin via proxy).
# In production (Vercel), set to your deployed CMS backend, e.g.:
#   VITE_API_BASE=https://portfolio-cms.onrender.com
VITE_API_BASE=

# ── Backend (server/index.js) — set these on the HOST, not here ───
# Local dev needs NONE of these — the server uses a JSON file store when
# SUPABASE_URL is unset. Production (Render) needs all of them:
#
# NODE_ENV=production
# CROSS_SITE=true                        # cross-site cookie (frontend/API split hosts)
# CLIENT_ORIGIN=https://your.vercel.app  # comma-separated allowlist
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_KEY=<service_role secret key>
# JWT_SECRET=<long random string>        # stable login secret across restarts
# SUPABASE_BUCKET=media                  # optional (default: media)
# PORT=5174                              # host usually sets this
